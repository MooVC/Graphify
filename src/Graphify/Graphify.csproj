      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Strategies\AsynchronousRegistrationStrategy.Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>AsynchronousRegistrationStrategy.Resources.resx</DependentUpon>
    </Compile>
    <Compile Update="NavigatorExtensionsGenerator.Resources.Designer.cs">
      <DependentUpon>NavigatorExtensionsGenerator.Resources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="TraverseAttributeGenerator.Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>TraverseAttributeGenerator.Resources.resx</DependentUpon>
    </Compile>
    <Compile Update="Strategies\ModelStrategy.Resources.Designer.cs">
      <DependentUpon>ModelStrategy.Resources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Strategies\AsynchronousContractStrategy.Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>AsynchronousContractStrategy.Resources.resx</DependentUpon>
    </Compile>
    <Compile Update="Strategies\SynchronousContractStrategy.Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>SynchronousContractStrategy.Resources.resx</DependentUpon>
    </Compile>
    <Compile Update="Strategies\AsynchronousVisitorStrategy.Resources.Designer.cs">
      <DependentUpon>AsynchronousVisitorStrategy.Resources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="Strategies\SynchronousVisitorStrategy.Resources.Designer.cs">
      <DependentUpon>SynchronousVisitorStrategy.Resources.resx</DependentUpon>
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
    </Compile>
    <Compile Update="TypeGenerator.Resources.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>TypeGenerator.Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Collections.Immutable" />
    <EmbeddedResource Update="GraphifyAttributeAnalyzer.Resources.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>GraphifyAttributeAnalyzer.Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="GraphifyAttributeGenerator.Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
