    <EmbeddedResource Update="Strategies\SynchronousContractStrategy.Resources.resx">
      <Generator>ResXFileCodeGenerator</Generator>
      <LastGenOutput>SynchronousContractStrategy.Resources.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="Strategies\AsynchronousVisitorStrategy.Resources.resx">
